{
  "name": "petopia-backend",
  "version": "1.0.0",
  "description": "Petopia Marketplace - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:drop": "node config/drop.js",
